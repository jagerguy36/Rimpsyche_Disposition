<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Industrious</defName>
    <positiveLabel>fast workspeed</positiveLabel>
    <negativeLabel>slow workspeed</negativeLabel>
    <positiveDescription>The pawn works more diligently.</positiveDescription>
    <negativeDescription>The pawn works at a leisurely pace.</negativeDescription>
    <threshold>0.3</threshold>
    <strongThreshold>0.5</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.IndustriousDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Ambitious</defName>
    <positiveLabel>Achievement driven</positiveLabel>
    <positiveDescription>The pawn feels greater sense of achievement, but grows unhappy if they accomplish nothing for too long.</positiveDescription>
    <threshold>0.4</threshold>
    <strongThreshold>0.8</strongThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.AmbitiousDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Resilient</defName>
    <positiveLabel>low mental break threshold</positiveLabel>
    <negativeLabel>high mental break threshold</negativeLabel>
    <positiveDescription>The pawn is less likely to suffer mental breaks.</positiveDescription>
    <negativeDescription>The pawn is more likely to suffer mental breaks.</negativeDescription>
    <threshold>0.3</threshold>
    <strongThreshold>0.5</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.ResilientDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Optimistic</defName>
    <positiveLabel>positive mood bias</positiveLabel>
    <negativeLabel>negative mood bias</negativeLabel>
    <positiveDescription>Positive events affect the pawn more strongly, while negative events affect them less.</positiveDescription>
    <negativeDescription>Negative events affect the pawn more strongly, while positive events affect them less.</negativeDescription>
    <threshold>0.3</threshold>
    <strongThreshold>0.5</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.OptimisticDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Stoic</defName>
    <positiveLabel>reduced mood variance</positiveLabel>
    <positiveDescription>The pawn experiences weaker emotional highs and lows.</positiveDescription>
    <threshold>0.4</threshold>
    <strongThreshold>0.8</strongThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.StoicDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Modest</defName>
    <positiveLabel>overwhelmed by shame</positiveLabel>
    <positiveDescription>The pawn becomes embarrassed when dressed improperly and may flee in shame.</positiveDescription>
    <threshold>0.1</threshold>
    <strongThreshold>0.3</strongThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.ModestDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Fierce</defName>
    <positiveLabel>adrenaline rush</positiveLabel>
    <positiveDescription>The pawn may experience adrenaline rush after being injured.</positiveDescription>
    <threshold>0.15</threshold>
    <strongThreshold>0.4</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.FierceDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Cowardly</defName>
    <positiveLabel>flee in panic</positiveLabel>
    <positiveDescription>The pawn may panic and flee after being injured.</positiveDescription>
    <threshold>0.15</threshold>
    <strongThreshold>0.4</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.CowardlyDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Experimental</defName>
    <positiveLabel>high quality variance</positiveLabel>
    <negativeLabel>low quality variance</negativeLabel>
    <positiveDescription>The pawn's work quality varies more, and they occasionally experiment to produce unexpectedly good or poor results.</positiveDescription>
    <negativeDescription>The pawn consistently produces work of similar quality.</negativeDescription>
    <threshold>0.3</threshold>
    <strongThreshold>0.5</strongThreshold>
    <extremeThreshold>0.7</extremeThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.ExperimentalDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

  <Maux36.RimPsyche.PsycheDescriptorDef>
    <defName>RPD_Desc_Organized</defName>
    <positiveLabel>workspace sensitive</positiveLabel>
    <negativeLabel>workspace insensitive</negativeLabel>
    <positiveDescription>The pawn's work speed depends heavily on having an appropriate workspace.</positiveDescription>
    <negativeDescription>The pawn's work speed is less affected by their workspace.</negativeDescription>
    <threshold>0.4</threshold>
    <strongThreshold>0.8</strongThreshold>
    <workerClass>Maux36.RimPsyche.Disposition.OrganizedDescriptorWorker</workerClass>
  </Maux36.RimPsyche.PsycheDescriptorDef>

